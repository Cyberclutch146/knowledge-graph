generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Graph {
  id        String   @id @default(cuid())
  title     String
  version   Int      @default(1)
  createdAt DateTime @default(now())
  nodes     Node[]
  edges     Edge[]
}

model Node {
  id      String @id @default(cuid())
  label   String
  type    String @default("concept")
  graphId String
  graph   Graph  @relation(fields: [graphId], references: [id], onDelete: Cascade)

  @@index([graphId])
  @@unique([label, graphId])
}

model Edge {
  id      String @id
  source  String
  target  String
  label   String
  graphId String
  graph   Graph  @relation(fields: [graphId], references: [id], onDelete: Cascade)

  @@index([graphId])
  @@unique([source, label, target, graphId])
}
